# GitHub Configuration
G_TOKEN=your_github_personal_access_token_here
G_USERNAME=Dimasick-git

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: comma-separated list of repo names to skip monitoring
# Example: SKIP_REPOS=Ryazhahand-Overlay,Sys-clk,Atmosphere
SKIP_REPOS=

# Optional: Telegram topic/thread ID for supergroups
TELEGRAM_TOPIC_ID=

# Optional: Anthropic API key for AI-powered commit summaries
# When set, each batch of new commits gets a 1-2 sentence Russian summary
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# Optional: Discord webhook URL for mirror notifications
# Get from: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# When set, all Telegram notifications are also mirrored to Discord
DISCORD_WEBHOOK_URL=
